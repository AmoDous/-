NODE_ENV=development
HOST=127.0.0.1
PORT=3001
LOG_LEVEL=info
PUBLIC_SITE_URL=https://amodous.github.io/Rooms-bron
PUBLIC_API_URL=http://127.0.0.1:3001
MEDIA_STORAGE_DIR=server-data/media
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:4173,http://127.0.0.1:4173,https://amodous.github.io
DATABASE_URL=
# DATABASE_URL=postgresql://rooms:change-me@localhost:5432/rooms
DATABASE_SSL=disable
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
ALLOW_DEMO_SEED=false
DEMO_PARTNER_PASSWORD=rooms2026
DEMO_ADMIN_PASSWORD=rooms2026
DEMO_ACCOUNTANT_PASSWORD=rooms2026
AUTH_TOKEN_SECRET=
# Production requires HTTPS URLs, a 32+ byte secret and secure cookies.
AUTH_COOKIE_SECURE=false
ENABLE_DEMO_PAYMENTS=true
PAYMENT_PROVIDER=demo
# Test: https://ecomtest.sberbank.ru  Production: use the URL issued during onboarding.
SBER_API_BASE_URL=
SBER_USERNAME=
SBER_PASSWORD=
SBER_REQUEST_TIMEOUT_MS=8000
# With PAYMENT_PROVIDER=sber the worker is enabled when this variable is omitted.
# REFUND_WORKER_ENABLED=true
REFUND_WORKER_INTERVAL_MS=5000
REFUND_WORKER_BATCH_SIZE=20
EXPOSE_PASSWORD_RESET_TOKEN=false
NOTIFICATION_ENCRYPTION_KEY=
FINANCE_ENCRYPTION_KEY=
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_INTERVAL_MS=5000
NOTIFICATION_WORKER_BATCH_SIZE=50
# log records delivery without sending or logging message contents; use live only with configured providers.
NOTIFICATION_DELIVERY_MODE=log
SMTP_URL=
EMAIL_FROM=
TELEGRAM_BOT_TOKEN=
FISCAL_RECEIPT_MODE=disabled
FISCAL_RECEIPT_WORKER_ENABLED=false
FISCAL_RECEIPT_WORKER_INTERVAL_MS=5000
FISCAL_RECEIPT_WORKER_BATCH_SIZE=20
